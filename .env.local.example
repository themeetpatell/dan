# Copy to .env.local and fill in ONE provider. Never commit .env.local.

# Option 1 — Anthropic (takes precedence when both are set)
ANTHROPIC_API_KEY=

# Option 2 — any OpenAI-compatible API (Groq, OpenRouter, Zhipu, …)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=moonshotai/kimi-k2-instruct-0905
